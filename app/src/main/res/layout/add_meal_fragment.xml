<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@color/white">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Meal"
            android:textSize="20dp"
            android:gravity="center"
            />


        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/input_name" android:hint="Meal name"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type"
            android:textSize="20dp"
            android:gravity="center"
            />

        <!--        MEAL's Type  -->

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <RadioButton
                android:id="@+id/isMeal"
                android:layout_width="100dp"
                android:gravity="center"
                android:checked="true"
                android:layout_height="wrap_content"

                android:text="MEAL"/>

            <RadioButton
                android:id="@+id/isDrink"
                android:layout_width="100dp"
                android:gravity="center"

                android:layout_height="wrap_content"
                android:text="Drink"/>


        </RadioGroup>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black"
            android:layout_margin="5dp"/>

        <TextView
            android:id="@+id/tv_Calorie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calorie /100g"
            android:textSize="20dp"
            android:gravity="center"
            />

        <EditText
            android:layout_width="match_parent"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:id="@+id/input_calories"
            android:text="1"

            android:inputType="number"/>




        <!--        // horizontal line-->


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Extra Info"
            android:textSize="20dp"
            android:gravity="center"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_Protein"
                android:gravity="center"
                android:layout_width="100dp"
                android:textSize="18sp"
                android:layout_height="wrap_content"
                android:text="Protein /g:"/>
            <EditText
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/input_protein"
                android:text="0"
                />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_Carbs"
                android:gravity="center"
                android:layout_width="100dp"
                android:textSize="18sp"
                android:layout_height="wrap_content"
                android:text="Carbs /g:"/>
            <EditText
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/input_carbs" android:text="0"/>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_Fat"
                android:gravity="center"
                android:layout_width="100dp"
                android:textSize="18sp"
                android:layout_height="wrap_content"
                android:text="Fat /g:"/>
            <EditText
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/input_fat"
                android:text="0"/>


        </LinearLayout>

        <LinearLayout

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_Sugar"
                android:gravity="center"
                android:layout_width="100dp"
                android:textSize="18sp"
                android:layout_height="wrap_content"
                android:text="Sugar /g:"/>
            <EditText
                android:layout_width="match_parent"
                android:inputType="numberDecimal"
                android:layout_height="wrap_content"
                android:id="@+id/input_sugar"
                android:text="0"/>

        </LinearLayout>


        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/btn_save"
            android:text="Save Meal"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/btn_save_add_Meal"
            android:text="Save and Add Meal"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/btnAdd_Meal"
            android:text="Add Meal WithOut Saving"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/btnSave_Changes"
            android:text="Save Changes"
            android:visibility="gone"/>



    </LinearLayout>



</ScrollView>

